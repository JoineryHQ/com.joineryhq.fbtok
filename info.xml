<?xml version="1.0"?>
<extension key="com.joineryhq.fbhash" type="module">
  <file>fbhash</file>
  <name>FormBuilder Hash Filters</name>
  <description>Allows site administrators to specify that, for certain FormBuilder forms, certain url parameters should be hashed in a way that makes them hard to guess.</description>
  <license>GPL-3.0</license>
  <authors>
    <author>
      <name>Allen Shaw</name>
      <email>allen@JoineryHQ.com</email>
      <role>Maintainer</role>
    </author>
  </authors>
  <urls>
    <url desc="Main Extension Page">https://github.com/JoineryHQ/com.joineryhq.fbhash</url>
    <url desc="Documentation">https://github.com/JoineryHQ/com.joineryhq.fbhash/blob/master/README.md</url>
    <url desc="Support">https://github.com/JoineryHQ/com.joineryhq.fbhash/issues</url>
    <url desc="Licensing">https://www.gnu.org/licenses/gpl-3.0.html</url>
  </urls>
  <releaseDate>2025-11-05</releaseDate>
  <version>1.0.0</version>
  <develStage>beta</develStage>
  <compatibility>
    <ver>6.4</ver>
  </compatibility>
  <comments>This extension will limit access to existing FormBuilder forms, depending on configuration. See documentation.</comments>
  <classloader>
    <psr0 prefix="CRM_" path="."/>
    <psr4 prefix="Civi\" path="Civi"/>
  </classloader>
  <civix>
    <namespace>CRM/Fbhash</namespace>
    <format>25.01.1</format>
    <angularModule>crmFbhash</angularModule>
  </civix>
  <mixins>
    <mixin>mgd-php@1.0.0</mixin>
    <mixin>setting-php@1.0.0</mixin>
    <mixin>smarty@1.0.3</mixin>
  </mixins>
  <upgrader>CiviMix\Schema\Fbhash\AutomaticUpgrader</upgrader>
</extension>
